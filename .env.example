# Example environment variables for Playwright tests
# Copy this file to .env and fill secrets (do NOT commit .env)

# Project selection: alpha|beta|prod
PROJECT_NAME=beta

# Execution mode
HEADLESS=false           # true = sin interfaz gráfica, false = ver navegador
SLOW_MO=500             # Milisegundos de pausa entre acciones (0 = sin pausa)

# ALPHA env
ALPHA_USER=qaauto
ALPHA_PASS=qaauto
ALPHA_URL=https://alpha.example.local

# BETA env (default target)
BETA_USER=qaauto
BETA_PASS=qaauto
BETA_URL=https://betabqc.ghtcorptest.com/

# PROD env
PROD_USER=qaauto
PROD_PASS=qaauto
PROD_URL=https://prod.example.local
